# VectorWorks — Environment Variables
# Copy this file to .env and fill in your values.

# NVIDIA NIM API key — get one at https://build.nvidia.com
# NOTE: This is a SERVER-SIDE variable (no VITE_ prefix) — it is never exposed
# to the browser bundle. In dev, api/nim.ts reads it via process.env.
# In production (Vercel), add it via: vercel env add NVIDIA_NIM_API_KEY
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# ── Auth (Clerk) — https://dashboard.clerk.com ─────────────────────────────────
# Publishable key — safe to expose in the browser bundle (VITE_ prefix required).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Secret key — SERVER-SIDE ONLY. Used by api/progress.ts to verify session tokens.
# Never prefix this with VITE_ — that would expose it to the browser.
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ── Per-user progress storage (Upstash Redis) — https://console.upstash.com ───
# Free tier is enough for "set of completed lesson keys per user".
# Both are SERVER-SIDE ONLY, read by api/progress.ts.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
