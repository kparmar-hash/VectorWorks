# VectorWorks — Environment Variables
# Copy this file to .env and fill in your values.

# NVIDIA NIM API key — get one at https://build.nvidia.com
# NOTE: This is a SERVER-SIDE variable (no VITE_ prefix) — it is never exposed
# to the browser bundle. In dev, api/nim.ts reads it via process.env.
# In production (Vercel), add it via: vercel env add NVIDIA_NIM_API_KEY
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

